# Dependencies
node_modules/

# Build and test output
dist/
coverage/
benchmarks/results/
.folderforge-ci/
.folderforge-soak/

# Logs
*.log
nohup.out
# Runtime / legacy artifacts (never commit these)
.trash/
**/.vibemcp/
# Per-project runtime state created at activation. The directory itself is
# tracked for fixtures, but live audit/approval logs must not be committed.
**/.folderforge/approvals.jsonl
**/.folderforge/audit/

# Distributed, marketplace, beta, artifact, and worker runtime state
**/.folderforge/distributed/
**/.folderforge/marketplace/
**/.folderforge/beta/
**/.folderforge/artifacts/
**/.folderforge/mcp-tasks/
**/.folderforge/worker-inputs/
**/.folderforge/worker-identity/

# Explicit local onboarding config created by `folderforge init`.
.folderforge/config.yaml

# OS / editor noise
.DS_Store
*.swp
.idea/
.vscode/
