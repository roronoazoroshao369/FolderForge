{
  "name": "@musashishao/folderforge",
  "version": "2.7.0",
  "description": "FolderForge - the all-in-one MCP-native local development control plane for AI coding agents.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "coding-agent",
    "claude",
    "cursor",
    "codex",
    "developer-tools",
    "workspace",
    "filesystem",
    "stdio",
    "cli"
  ],
  "homepage": "https://github.com/roronoazoroshao369/FolderForge#readme",
  "bugs": {
    "url": "https://github.com/roronoazoroshao369/FolderForge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roronoazoroshao369/FolderForge.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "bin": {
    "folderforge": "dist/main.js"
  },
  "main": "./dist/main.js",
  "imports": {
    "#adapter-godot": "./packages/adapter-godot/dist/index.js"
  },
  "files": [
    "dist",
    "packages/adapter-godot/dist",
    "packages/adapter-godot/package.json",
    "packages/adapter-godot/README.md",
    "packages/adapter-godot/LICENSE",
    "examples",
    "addons",
    "docs",
    "README.md",
    "LICENSE",
    "benchmarks",
    "beta",
    "scripts/benchmark-lib.mjs",
    "scripts/run-benchmarks.mjs",
    "scripts/validate-benchmark-results.mjs",
    "scripts/compare-benchmarks.mjs",
    "scripts/beta-evidence.mjs",
    "scripts/release-provenance-lib.mjs",
    "scripts/create-release-bundle.mjs",
    "scripts/verify-release-bundle.mjs",
    "scripts/evidence.mjs",
    "scripts/child-mcp-compatibility.mjs",
    "scripts/child-mcp-third-party.mjs",
    "compatibility/child-mcp-third-party.json",
    "scripts/runtime-soak.mjs",
    "scripts/runtime-soak-lib.mjs",
    "scripts/test-runtime-soak-volume.mjs",
    "scripts/run-governance-benchmarks.mjs"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build:adapter-godot": "tsc -p packages/adapter-godot/tsconfig.json",
    "build": "npm run build:adapter-godot && tsc -p tsconfig.json && node scripts/copy-static-assets.mjs && node scripts/ensure-bin-mode.mjs",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/main.js",
    "setup:browser": "node dist/main.js setup browser",
    "prepare": "npm run build",
    "typecheck": "npm run build:adapter-godot && tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"packages/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "architecture:check": "node scripts/check-architecture.mjs",
    "verify": "npm run typecheck && npm run lint && npm run architecture:check && npm test && npm run build",
    "smoke:package": "node scripts/smoke-package.mjs",
    "smoke:http": "node scripts/smoke-http.mjs",
    "release:check": "npm run verify && npm run quality:check && npm run docs:check && npm audit --omit=dev && npm audit && npm run smoke:package && npm run smoke:stdio && npm run smoke:http",
    "prepublishOnly": "npm run release:check",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json --coverage.reporter=json-summary && npm run coverage:critical",
    "coverage:critical": "node scripts/check-critical-coverage.mjs",
    "test:fuzz": "vitest run tests/fuzz/core.fuzz.test.ts",
    "test:stress": "node scripts/stress-child-mcp.mjs",
    "test:audit-concurrency": "node scripts/test-audit-concurrency.mjs",
    "compatibility:child-mcp": "npm run build && node scripts/child-mcp-compatibility.mjs",
    "compatibility:child-mcp:third-party": "npm run build && node scripts/child-mcp-third-party.mjs",
    "release:inventory:capture": "node scripts/capture-release-inventory.mjs --output docs/release-inventory.json --markdown docs/release-inventory.md",
    "release:bundle:verify": "node scripts/verify-release-bundle.mjs",
    "evidence:verify": "npm run build && node scripts/evidence.mjs verify",
    "evidence:migrate": "npm run build && node scripts/evidence.mjs migrate",
    "smoke:evidence": "npm run build && node scripts/smoke-evidence.mjs",
    "smoke:onboarding": "npm run build && node scripts/smoke-onboarding.mjs",
    "smoke:adapter-godot": "node scripts/smoke-adapter-godot.mjs",
    "smoke:inspector": "npm run build && node scripts/smoke-inspector.mjs",
    "smoke:runtime-soak": "npm run build && node scripts/runtime-soak.mjs --output-dir .folderforge-ci/runtime-soak-smoke --duration-ms 5000 --interval-ms 250 --fault-every 5 --reset",
    "soak:runtime": "npm run build && node scripts/runtime-soak.mjs",
    "soak:runtime:24h": "npm run build && node scripts/runtime-soak.mjs --duration-ms 86400000 --interval-ms 1000 --fault-every 300",
    "test:runtime-soak-volume": "node scripts/test-runtime-soak-volume.mjs",
    "quality:check": "npm run test:coverage && npm run test:fuzz && npm run test:stress && npm run smoke:inspector && npm run test:audit-concurrency && npm run smoke:evidence && npm run compatibility:child-mcp && node scripts/child-mcp-third-party.mjs --validate-only && npm run smoke:runtime-soak && npm run test:runtime-soak-volume && npm run smoke:onboarding && npm run smoke:adapter-godot && npm run benchmark:governance",
    "benchmark:validate": "node scripts/validate-benchmark-results.mjs",
    "benchmark:compare": "node scripts/compare-benchmarks.mjs",
    "smoke:sandbox": "node scripts/smoke-sandbox.mjs",
    "benchmark:run": "node scripts/run-benchmarks.mjs",
    "benchmark:governance": "npm run build && node scripts/run-governance-benchmarks.mjs",
    "beta:ingest": "node scripts/beta-evidence.mjs ingest",
    "beta:report": "node scripts/beta-evidence.mjs report"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@playwright/mcp": "^0.0.41",
    "execa": "^10.0.0",
    "fast-glob": "^3.3.0",
    "ignore": "^6.0.0",
    "jose": "^6.2.3",
    "pino": "^9.0.0",
    "pngjs": "7.0.0",
    "simple-git": "^3.25.0",
    "tar": "^7.5.20",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@modelcontextprotocol/inspector": "0.21.2",
    "@types/node": "^22.0.0",
    "@types/pngjs": "6.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "fast-check": "^4.3.0",
    "globals": "^16.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
