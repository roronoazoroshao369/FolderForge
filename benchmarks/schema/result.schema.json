{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/roronoazoroshao369/FolderForge/benchmarks/schema/result.schema.json",
  "title": "FolderForge agent benchmark result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "taskManifestSha256", "system", "runs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "suite": { "type": "string", "minLength": 1 },
    "taskManifestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "commit", "agent", "model", "os", "hardware"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 7 },
        "agent": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "os": { "type": "string", "minLength": 1 },
        "hardware": { "type": "string", "minLength": 1 }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "run", "success", "securityPass", "durationMs", "toolCalls", "approvals", "unintendedFiles"],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "run": { "type": "integer", "minimum": 1 },
          "success": { "type": "boolean" },
          "securityPass": { "type": "boolean" },
          "durationMs": { "type": "integer", "minimum": 0 },
          "toolCalls": { "type": "integer", "minimum": 0 },
          "tokens": { "type": "integer", "minimum": 0 },
          "approvals": { "type": "integer", "minimum": 0 },
          "unintendedFiles": { "type": "integer", "minimum": 0 },
          "evidenceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "notes": { "type": "string", "maxLength": 2000 }
        }
      }
    }
  }
}
